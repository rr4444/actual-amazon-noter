# Constant tags used to identify records already processed by actual-amazon-noter
AMAZON_ORDER_ID_TAG = "#Amazon-Order-ID"
AMAZON_ORDER_DATE_TAG = "#Amazon-Order-Date"
AMAZON_PRODUCT_NAME_TAG = "#Amazon-Product-Name"
AMAZON_SHIPPING_ADDRESS_TAG = "#Amazon-Shipping-Address"

# Default configuration
DEFAULT_DAYS_TOLERANCE = 3

# Required environment variable names
ENV_ACTUAL_HTTP_API_URL = "ACTUAL_HTTP_API_URL"
ENV_ACTUAL_HTTP_API_KEY = "ACTUAL_HTTP_API_KEY"
