    """Main entry point."""
    parser = argparse.ArgumentParser(
        description=f"Update Actual Budget transaction notes with Amazon order details (v{VERSION})",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=f"""
Version: {VERSION}

Examples:
    actual-amazon-noter Order_History.csv
        Use environment variables for connection details, dry-run mode
    
    actual-amazon-noter --execute --actual-http-api-file /path/to/config Order_History.csv
        Update records in Actual Budget using config file
    
    actual-amazon-noter --days 5 --force Order_History.csv Refund_Details.csv
        Match within 5 days, replace existing tags
"""
    )
    
    # Mode arguments
    mode_group = parser.add_mutually_exclusive_group()
    mode_group.add_argument(
        "--dry-run",
        nargs="?",  # Allows --dry-run without value, but also --dry-run json
        const="csv",
        default="csv",
        choices=["csv", "json"],
        help="Dry-run mode (default). Use --dry-run json for JSON output"
    )
    mode_group.add_argument(
        "--execute",
        action="store_true",
        help="Actually update records in Actual Budget"
    )
    
    # Matching options
    parser.add_argument(
        "--days",
        type=int,
        default=DEFAULT_DAYS_TOLERANCE,
        help=f"Number of days tolerance for date matching (default: {DEFAULT_DAYS_TOLERANCE})"
    )
    parser.add_argument(
        "--force",
        action="store_true",
        help="Replace existing Amazon tags in notes field"
    )
    parser.add_argument(
        "-t",
        "--tag",
        dest="user_tags",
        action="append",
        default=None,
        help="Add custom tag to matching transactions (can be used multiple times)"
    )
    
    # Connection arguments - URL
    parser.add_argument(
        "--actual-http-api",
        dest="actual_http_api",
        help="URL of actual-http-api server"
    )
    parser.add_argument(
        "--actual-http-api-file",
        dest="actual_http_api_file",
        help="Path to file containing API URL"
    )
    
    # Connection arguments - Key
    parser.add_argument(
        "--actual-http-api-key",
        dest="actual_http_api_key",
        help="Secret key for actual-http-api"
    )
    parser.add_argument(
        "--actual-http-api-key-file",
        dest="actual_http_api_key_file",
        help="Path to file containing API key"
    )
    
    # Connection arguments - SyncID
    parser.add_argument(
        "--actual-syncid",
        dest="actual_syncid",
        help="Budget synchronization ID"
    )
    parser.add_argument(
        "--actual-syncid-file",
        dest="actual_syncid_file",
        help="Path to file containing SyncID"
    )
    
    # Connection arguments - BudgetID
    parser.add_argument(
        "--actual-budgetid",
        dest="actual_budgetid",
        help="Budget ID (from /v1/budgets endpoint)"
    )
    parser.add_argument(
        "--actual-budgetid-file",
        dest="actual_budgetid_file",
        help="Path to file containing BudgetID"
    )
    
    # CSV file arguments
    parser.add_argument(
        "csv_files",
        nargs="+",
        help="CSV files containing Amazon transaction records"
    )
    
    args = parser.parse_args()
    
    # Determine mode
    dry_run = not args.execute
    if args.dry_run == "csv":
        output_format = "csv"
    else:
        output_format = args.dry_run
    
    # If files point to same config file, preload it once
    actual_http_api_file = None
    actual_http_api_key_file = None
    actual_syncid_file = None
    
    # Check if all file arguments point to same file
    if (args.actual_http_api_file and 
        args.actual_http_api_file == args.actual_http_api_key_file == args.actual_syncid_file == args.actual_budgetid_file):
        config = parse_config_file(args.actual_http_api_file)
    else:
        config = {}
        
    # Get required configuration values
    try:
        api_url = get_config_value(
            args.actual_http_api,
            ENV_ACTUAL_HTTP_API_URL,
            args.actual_http_api_file,
            config
        )
        api_key = get_config_value(
            args.actual_http_api_key,
            ENV_ACTUAL_HTTP_API_KEY,
            args.actual_http_api_key_file,
            config
        )
        sync_id = get_config_value(
            args.actual_syncid,
            ENV_ACTUAL_SYNCID,
            args.actual_syncid_file,
            config
        )
        budget_id = get_config_value(
            args.actual_budgetid,
            ENV_ACTUAL_BUDGETID,
            args.actual_budgetid_file,
            config
        )
    except ValueError as e:
        parser.error(str(e))
    
    # Validate required arguments
    missing = []
    if not api_url:
        missing.append(ENV_ACTUAL_HTTP_API_URL)
    if not api_key:
        missing.append(ENV_ACTUAL_HTTP_API_KEY)
    if not sync_id:
        missing.append(ENV_ACTUAL_SYNCID)
    
    if missing:
        print(f"Error: Missing required arguments: {', '.join(missing)}", file=sys.stderr)
        print(f"These can be provided via environment variables or command-line arguments.", file=sys.stderr)
        print(f"", file=sys.stderr)
        print(f"Environment variables:", file=sys.stderr)
        print(f"  {ENV_ACTUAL_HTTP_API_URL}", file=sys.stderr)
        print(f"  {ENV_ACTUAL_HTTP_API_KEY}", file=sys.stderr)
        print(f"  {ENV_ACTUAL_SYNCID}", file=sys.stderr)
        sys.exit(1)
    
    # Validate CSV files
    csv_files = args.csv_files
    if not csv_files:
        print("Error: At least one CSV file must be provided", file=sys.stderr)
        sys.exit(1)
    
    # Read Amazon CSV files
    all_amazon_records = []
    for csv_file in csv_files:
        if not os.path.exists(csv_file):
            print(f"Error: File not found: {csv_file}", file=sys.stderr)
            sys.exit(1)
        
        record_type, records = read_amazon_csv(csv_file)
        all_amazon_records.extend(records)
        print(f"Loaded {len(records)} records from {csv_file} ({record_type})")
    
    if not all_amazon_records:
        print("Error: No Amazon records found in CSV files", file=sys.stderr)
        sys.exit(1)
    
    # Connect to Actual Budget API
    api = ActualBudgetAPI(api_url, api_key, sync_id)
    
    # Get transactions with "Amazon" in payee
    print("Fetching transactions from Actual Budget...")
    all_transactions = api.get_all_transactions()
    search_lower = "amazon"
    search_lower2 = "amz"
    transactions = [
        t for t in all_transactions
        if search_lower in (t.get("payee_name") or "").lower() or
           search_lower in (t.get("imported_payee") or "").lower() or
           search_lower2 in (t.get("payee_name") or "").lower() or
           search_lower2 in (t.get("imported_payee") or "").lower()
    ]
    print(f"Found {len(transactions)} transactions with 'Amazon' in payee")
    
    # Categorize Amazon records (withdrawals vs income/refunds)
    purchase_records = [r for r in all_amazon_records if r.amount > 0]
    refund_records = [r for r in all_amazon_records if r.amount < 0]
    
    # Find matches
    purchase_matches = match_transactions(transactions, purchase_records, args.days, is_income=False)
    refund_matches = match_transactions(transactions, refund_records, args.days, is_income=True)
    
    all_matches = purchase_matches + refund_matches
    print(f"Found {len(all_matches)} potential matches")
    
    # Process user-provided tags
    user_tags_normalized = process_user_tags(args.user_tags)
    if user_tags_normalized:
        print(f"User tags to append: {' '.join(user_tags_normalized)}")
    
    # Process matches
    updated_count = 0
    skipped_count = 0
    error_count = 0
    split_count = 0
    
    for transaction, amazon_record in all_matches:
        original_notes = transaction.get("notes", "")
        amazon_tags = amazon_record.get_tags()
        # Append user-provided tags to Amazon tags
        amazon_tags.extend(user_tags_normalized)
        new_notes = create_updated_notes(original_notes, amazon_tags, args.force)
        
        # Skip if notes haven't changed
        if new_notes == original_notes:
            skipped_count += 1
            continue
        
        if dry_run:
            # Print changes without updating
            if output_format == "csv":
                print_dry_run_csv(transaction, amazon_record, original_notes, new_notes)
            else:
                print_dry_run_json(transaction, amazon_record, original_notes, new_notes)
            # Show split preview for multi-item orders
            if hasattr(amazon_record, 'product_names') and len(amazon_record.product_names) > 1:
                if transaction.get("is_parent") and not args.force:
                    print(f"  [SKIP SPLIT] Already a split transaction")
                else:
                    sign = -1 if transaction.get("amount", 0) < 0 else 1
                    splits_preview = []
                    for pname, iamt in zip(amazon_record.product_names, amazon_record.item_amounts):
                        splits_preview.append({"amount": int(round(iamt * 100)) * sign, "notes": pname})
                    parent_amount = transaction.get("amount", 0)
                    sub_sum = sum(s["amount"] for s in splits_preview)
                    if sub_sum != parent_amount:
                        splits_preview[-1]["amount"] += (parent_amount - sub_sum)
                    ccy = getattr(amazon_record, 'currency', 'GBP')
                    print(f"  SPLIT: Would create {len(splits_preview)} sub-transactions:")
                    for idx, sp in enumerate(splits_preview):
                        print(f"    Sub {idx+1}: {ccy} {abs(sp['amount'])/100:.2f} \u2014 {sp['notes'][:80]}")
            updated_count += 1
        else:
            # Actually update the transaction
            try:
                api.update_transaction(transaction["id"], new_notes)
                print(f"Updated transaction {transaction['id']}")
                updated_count += 1
                # Create splits for multi-item orders
                if hasattr(amazon_record, 'product_names') and len(amazon_record.product_names) > 1:
                    if transaction.get("is_parent") and not args.force:
                        print(f"  Already split \u2014 skipping split creation")
                    else:
                        children = []
                        if transaction.get("is_parent") and args.force:
                            print(f"  Already split \u2014 --force used, recreating splits...")
                            children = [t for t in all_transactions if t.get("parent_id") == transaction["id"]]
                            for child in children:
                                try:
                                    print(f"  [DEBUG] Deleting old child {child['id']}...")
                                    api.delete_transaction(child["id"])
                                except Exception as e:
                                    print(f"  [DEBUG] Failed to delete child {child['id']}: {e}")
                        account_id = transaction.get("account", "")
                        trans_date = transaction.get("date", "")
                        payee_id = transaction.get("payee", "")
                        sign = -1 if transaction.get("amount", 0) < 0 else 1
                        splits = []
                        for pname, iamt in zip(amazon_record.product_names, amazon_record.item_amounts):
                            amt = int(round(iamt * 100)) * sign
                            splits.append({"amount": amt, "notes": pname})
                            print(f"  [DEBUG] Sub: {pname[:60]}  raw_amt={iamt}  calculated={amt}")
                        # Correct rounding: adjust last sub so sum matches parent exactly
                        parent_amount = transaction.get("amount", 0)
                        sub_sum = sum(s["amount"] for s in splits)
                        if sub_sum != parent_amount:
                            adj = parent_amount - sub_sum
                            splits[-1]["amount"] += adj
                            print(f"  [DEBUG] Rounding adjustment: {adj} (parent={parent_amount}, sub_sum={sub_sum})")
                        print(f"  [DEBUG] Final splits: {[(s['amount'], s['notes'][:40]) for s in splits]}")
                        try:
                            api.split_transaction(transaction["id"], account_id, trans_date, payee_id, splits)
                            print(f"  Split into {len(splits)} sub-transactions")
                            split_count += 1
                        except Exception as e:
                            print(f"  Error splitting {transaction['id']}: {e}", file=sys.stderr)
                            error_count += 1
            except Exception as e:
                print(f"Error updating transaction {transaction['id']}: {e}", file=sys.stderr)
                error_count += 1
    
    # Print summary
    print()
    print(f"Summary:")
    print(f"  Total matches found: {len(all_matches)}")
    print(f"  Records updated: {updated_count}")
    print(f"  Records skipped (already processed): {skipped_count}")
    print(f"  Transactions split: {split_count}")
    if error_count > 0:
        print(f"  Errors: {error_count}", file=sys.stderr)
    if dry_run:
        print(f"  Mode: DRY-RUN (use --execute to actually update)")
    else:
        print(f"  Mode: EXECUTE (records have been updated)")
    
    if error_count > 0:
        sys.exit(1)


if __name__ == "__main__":
    main()